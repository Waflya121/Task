# ==== Nova Auth Server — пример переменных окружения ====
# Скопируйте этот файл в `.env` и заполните реальными значениями.

NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ---- PostgreSQL ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=auth_db

# ---- JWT ----
# Обязательно замените на длинную случайную строку в продакшене.
JWT_SECRET=your_secret_key_here
JWT_EXPIRES_IN=7d

# ---- SMTP (почта) ----
# Прямые исходящие SMTP-порты (25/465/587) блокированы почти на всех
# бюджетных хостингах и VDS-тарифах (защита от спама с скомпрометированных
# серверов). Если хостинг предоставляет собственный relay-сервер для этого
# тарифа (как skvmrelay.netangels.ru у NetAngels на VDS "Старт") — используйте
# его. В остальных случаях — обычный SMTP-аккаунт (Gmail + App Password,
# см. https://support.google.com/accounts/answer/185833) работает локально
# без ограничений; на хостинге см. документацию провайдера.
SMTP_HOST=skvmrelay.netangels.ru
SMTP_PORT=25
# У relay NetAngels для VDS "Старт" авторизация не нужна (доступ по IP)
# — оставьте пустыми. Для обычного SMTP-аккаунта (Gmail и т.п.) заполните.
SMTP_USER=
SMTP_PASS=

# From должен быть на домене/аккаунте, который реально имеет право
# отправлять письма через выбранный SMTP — иначе письмо отклонят.
MAIL_FROM="Nova <noreply@your-domain.example>"
