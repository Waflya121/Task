# ==== Nova Auth Server — пример переменных окружения ====
# Скопируйте этот файл в `.env` и заполните реальными значениями.

NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ---- PostgreSQL ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=auth_db

# ---- JWT ----
# Обязательно замените на длинную случайную строку в продакшене.
JWT_SECRET=your_secret_key_here
JWT_EXPIRES_IN=7d

# ---- SMTP (почта) ----
# Gmail: SMTP_PASS должен быть "App Password" (не обычный пароль аккаунта),
# см. https://support.google.com/accounts/answer/185833
# Учтите: многие хостинги (в т.ч. бесплатный план Render) блокируют исходящие
# SMTP-порты — локально всё работает, но на таком хостинге письма отправляться
# не будут. Для локальной разработки можно использовать Mailtrap или Ethereal.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# From должен совпадать с SMTP_USER — иначе Gmail отклоняет письмо или
# молча подменяет обратный адрес.
MAIL_FROM="Nova <your_email@gmail.com>"
