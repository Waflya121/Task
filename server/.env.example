# ==== Nova Auth Server — пример переменных окружения ====
# Скопируйте этот файл в `.env` и заполните реальными значениями.

NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ---- PostgreSQL ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=auth_db

# ---- JWT ----
# Обязательно замените на длинную случайную строку в продакшене.
JWT_SECRET=your_secret_key_here
JWT_EXPIRES_IN=7d

# ---- Email (UniSender HTTP API) ----
# Письма отправляются через HTTP API (не SMTP): SMTP-порты блокированы
# практически на всех бюджетных хостингах (проверено на Render и на VPS) —
# HTTPS-запросы к API такие блокировки не встречают. Зарегистрируйтесь на
# https://unisender.com, верифицируйте домен (Настройки → Домены — там же
# DNS-записи для SPF/DKIM) и создайте API-ключ.
UNISENDER_API_KEY=your_unisender_api_key_here
# ID списка контактов в UniSender (даже для одиночных писем классический
# API требует list_id).
UNISENDER_LIST_ID=1
# Email должен быть на домене, верифицированном в UniSender.
SENDER_EMAIL=no-reply@your-domain.example
SENDER_NAME=Nova
